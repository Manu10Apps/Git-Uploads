// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?
  parentId    Int?
  parent      Category? @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryParent")
  articles    Article[]
  translations CategoryTranslation[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  status      String    @default("active") // "active" or "archived"

  @@map("categories")
}

model Article {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String    @unique
  excerpt         String
  content         String    // Markdown or HTML
  image           String?
  categoryId      Int
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author          String
  authorSocialPlatform String?
  authorSocialUrl  String?
  authorSocialPlatform2 String?
  authorSocialUrl2 String?
  status          String    @default("draft") // "draft" | "published" | "scheduled" | "archived"
  publishedAt     DateTime?
  scheduledFor    DateTime?
  featured        Boolean   @default(false)
  readTime        Int       @default(5)
  tags            String?   // JSON array as string: '["tag1","tag2"]'
  gallery         String?   // JSON array as string: '[{"url":"...","caption":"..."}]'
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  comments        Comment[]
  translations    ArticleTranslation[]

  @@index([categoryId])
  @@index([status])
  @@index([publishedAt])
  @@map("articles")
}

model ArticleTranslation {
  id                Int       @id @default(autoincrement())
  articleId         Int
  article           Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  language          String    // "en" | "sw"
  title             String
  excerpt           String
  content           String
  seoTitle          String?
  seoDescription    String?
  galleryCaptions   String?   // JSON array as string: '[{"url":"...","caption":"..."}]'
  translationSource String    @default("ai") // "ai" | "manual" | "deepl" | "google"
  versionHash       String    // hash of original content at time of translation
  translatedAt      DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([articleId, language])
  @@index([articleId])
  @@index([language])
  @@map("article_translations")
}

model CategoryTranslation {
  id          Int       @id @default(autoincrement())
  categoryId  Int
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  language    String    // "en" | "sw"
  name        String
  description String?
  translatedAt DateTime @default(now())

  @@unique([categoryId, language])
  @@index([categoryId])
  @@map("category_translations")
}

model Comment {
  id        Int      @id @default(autoincrement())
  articleId Int
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  parentId  Int?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  votes     CommentVote[]
  name      String
  email     String
  content   String
  likes     Int      @default(0)
  dislikes  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([articleId])
  @@index([parentId])
  @@map("comments")
}

model CommentVote {
  id        Int      @id @default(autoincrement())
  commentId Int
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  visitorId String
  reaction  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([commentId, visitorId])
  @@index([visitorId])
  @@map("comment_votes")
}

model AdminUser {
  id                           Int       @id @default(autoincrement())
  email                        String    @unique
  password                     String    // Hash with bcrypt
  name                         String
  role                         String    @default("editor") // "admin" | "sub-admin" | "editor"
  emailVerified                Boolean   @default(false)
  emailVerificationToken       String?   @unique
  emailVerificationExpiresAt   DateTime?
  passwordResetToken           String?   @unique
  passwordResetExpiresAt       DateTime?
  refreshTokens                RefreshToken[]  // Phase 2: Support refresh tokens
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt
  epaperEditions               EpaperEdition[]

  @@map("admin_users")
}

// Phase 2: Refresh token model for JWT refresh flow
model RefreshToken {
  id            Int       @id @default(autoincrement())
  adminUserId   Int
  adminUser     AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  token         String    @unique
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  revokedAt     DateTime? // Null = valid; set = revoked

  @@index([adminUserId])
  @@index([token])
  @@map("refresh_tokens")
}

// Phase 3: Regular user/contributor/author model
model User {
  id                           Int       @id @default(autoincrement())
  email                        String    @unique
  password                     String    // Hash with bcrypt
  name                         String
  bio                          String?   // Author bio
  role                         String    @default("contributor") // "contributor" | "author" | "verified_author"
  status                       String    @default("pending_verification") // "pending_verification" | "active" | "suspended"
  emailVerified                Boolean   @default(false)
  emailVerificationToken       String?   @unique
  emailVerificationExpiresAt   DateTime?
  passwordResetToken           String?   @unique
  passwordResetExpiresAt       DateTime?
  refreshTokens                UserRefreshToken[] // Phase 2: Support refresh tokens for regular users
  auditLogs                    AuditLog[]
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  @@index([email])
  @@index([status])
  @@map("users")
}

// Phase 2: Refresh token model for regular users
model UserRefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime? // Null = valid; set = revoked

  @@index([userId])
  @@index([token])
  @@map("user_refresh_tokens")
}

// Phase 3: Audit log for tracking user/admin actions
model AuditLog {
  id          Int       @id @default(autoincrement())
  userId      Int?      // Null for system actions
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String    // "signup" | "login" | "verify_email" | "password_change" | "role_change" | "account_suspend"
  resourceType String   // "user" | "admin" | "article" | "comment"
  resourceId  Int?      // ID of affected resource
  details     String?   // JSON details
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model ExchangeRate {
  id        Int       @id @default(autoincrement())
  currency  String    @unique
  rate      Float
  change    Float     @default(0)
  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())

  @@map("exchange_rates")
}

model Advert {
  id        Int       @id @default(autoincrement())
  title     String
  url       String    @default("")
  imageUrl  String    @default("")
  position  String    @default("homepage_top")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt

  @@map("adverts")
}

model AnalyticsEvent {
  id               String    @id @default(cuid())
  sessionId        String    // Unique session identifier
  visitorId        String?   // Anonymous visitor ID
  eventType        String    // "pageview" | "click" | "custom" | "error"
  eventName        String?   // Custom event name
  pageUrl          String    // URL of the page
  pageTitle        String?   // Page title
  referrer         String?   // Referrer URL
  // User Agent / Device Info
  userAgent        String?
  deviceType       String?   // "mobile" | "tablet" | "desktop"
  browserName      String?   // Chrome, Firefox, Safari, etc.
  browserVersion   String?
  osName           String?   // Windows, macOS, iOS, Android, etc.
  // Geo Info
  country          String?
  city             String?
  latitude         Float?
  longitude        Float?
  // Session Data
  duration         Int?      // Time spent on page in seconds
  scrollDepth      Int?      // Percentage scrolled (0-100)
  // Custom Properties
  properties       String?   // JSON object as string for custom data
  // Timestamps
  createdAt        DateTime  @default(now())
  // Indexes for fast querying
  @@index([sessionId])
  @@index([visitorId])
  @@index([eventType])
  @@index([pageUrl])
  @@index([createdAt])
  @@index([country])
  @@map("analytics_events")
}

model AuthorSocialProfile {
  id             Int      @id @default(autoincrement())
  authorName     String   @unique
  socialLinks    Json     @default("{}")
  socialLocked   Boolean  @default(true)
  unlockedUntil  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  changeRequests SocialChangeRequest[]

  @@map("author_social_profiles")
}

model SocialChangeRequest {
  id              Int                 @id @default(autoincrement())
  authorId        Int
  author          AuthorSocialProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)
  requestedBy     String
  requestedByRole String
  requestedLinks  Json?
  status          String              @default("pending") // pending | approved | rejected
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime            @default(now())

  @@index([authorId])
  @@index([status])
  @@map("social_change_requests")
}

model EpaperEdition {
  id           Int       @id @default(autoincrement())
  title        String
  issueDate    DateTime  @db.Date     // Date when the edition was published
  coverImage   String?                // URL to cover image (for preview)
  pdfUrl       String?                // URL to the PDF file (null for drafts pending upload)
  fileSize     Int?                   // File size in bytes
  pageCount    Int       @default(0)  // Number of pages
  status       String    @default("published") // "draft" | "published"
  notes        String?                // Auto-generated article summary for the week
  isCurrent    Boolean   @default(false) // Mark as current/latest issue
  isArchived   Boolean   @default(false) // Soft delete indicator
  createdBy    Int
  admin        AdminUser @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  archivedAt   DateTime? // Timestamp when archived

  @@unique([issueDate])
  @@index([isCurrent])
  @@index([isArchived])
  @@index([status])
  @@index([createdAt])
  @@index([issueDate])
  @@map("epaper_editions")
}
