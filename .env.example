
# Database
DATABASE_URL=postgresql://app_user:Irafasha@2025@intambwe-media-news-database-4i70w2:5432/app_db
# Optional runtime override (recommended for production when DATABASE_URL host is build-only/internal)
DATABASE_URL_RUNTIME=postgresql://app_user:Irafasha@2025@intambwemedia.com:5432/app_bd?schema=public
# Enforce PostgreSQL in production runtime
STRICT_POSTGRESQL=true
# Keep fallback storage disabled in production (recommended)
ALLOW_FALLBACK_STORAGE=false

# Upload Storage
# In production (Docker/Dokploy), set to a persistent volume path so uploads survive container rebuilds.
# In development, leave unset to use the default (public/uploads/).
# UPLOAD_DIR=/data/uploads

# Admin Credentials
ADMIN_EMAIL=admin@amakuru.news
ADMIN_PASSWORD=AdminPassword123!

# Exchange Rate API Configuration
# API key for protecting the exchange rate update endpoints
EXCHANGE_RATE_API_KEY=your-secret-key-here

# Cron Secret
# Secret key for protecting the scheduled daily update endpoint
CRON_SECRET=your-cron-secret-key-here

# Optional: Base URL
NEXT_PUBLIC_BASE_URL=https://intambwemedia.com

# TimezoneDB API (Optional - for timezone detection in TopBar)
# Get free key at https://timezonedb.com/api
# Without this key, timezone defaults to coordinate-based estimation
NEXT_PUBLIC_TIMEZONEDB_KEY=YOUR_TIMEZONE_KEY

# AI News Generator (ChatGPT API)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional model override
# OPENAI_MODEL=gpt-4o-mini

# Example: For local development
# EXCHANGE_RATE_API_KEY=dev-key-12345
# CRON_SECRET=dev-cron-secret-abc
